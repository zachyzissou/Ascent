# Text files that should remain as text
*.txt text
*.md text
*.cpp text
*.h text
*.cs text
*.ini text
*.config text
*.json text
*.xml text
*.yaml text
*.yml text
*.bat text
*.sh text
*.py text
*.js text

# Line ending normalization for cross-platform development
*.cpp text eol=crlf
*.h text eol=crlf
*.cs text eol=crlf
*.ini text eol=crlf
*.config text eol=crlf
*.uproject text eol=crlf
*.uplugin text eol=crlf

# Shell scripts should use LF endings
*.sh text eol=lf
*.py text eol=lf